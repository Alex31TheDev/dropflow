{
  "include": ["src/**/*", "*.d.ts"],
  "exclude": [
    "node_modules",
    "examples",
    "test"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": true,
    "declaration": true,
    "lib": ["esnext"],
    "target": "esnext",
    "module": "node16",
    "strict": true,
    "noUnusedLocals": false,
    "stripInternal": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true
  }
}
